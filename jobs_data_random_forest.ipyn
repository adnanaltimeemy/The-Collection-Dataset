   "id": "740fe14e-d42a-4730-b133-852bdee4a621",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fill numeric missing values with median\n",
    "for col in df.select_dtypes(include=np.number).columns:\n",
    "    df[col] = df[col].fillna(df[col].median())\n",
    "\n",
    "# Fill categorical missing values with mode\n",
    "for col in df.select_dtypes(include=['object', 'string']).columns:\n",
    "    df[col] = df[col].fillna(df[col].mode()[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "a8cf191a-109b-41a3-b352-1e39b6c971e7",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import LabelEncoder\n",
    "\n",
    "label_encoders = {}\n",
    "\n",
    "# Explicitly include both 'object' and 'string' dtypes\n",
    "for col in df.select_dtypes(include=['object', 'string']).columns:\n",
    "    le = LabelEncoder()\n",
    "    df[col] = le.fit_transform(df[col])\n",
    "    label_encoders[col] = le"
   ]
  },
  {
   "cell_type": "code",
